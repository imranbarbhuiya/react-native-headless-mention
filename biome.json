{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": false
	},
	"formatter": {
		"lineWidth": 120,
		"lineEnding": "lf",
		"indentWidth": 4,
		"indentStyle": "tab",
		"includes": ["**", "!**/package.json"]
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "all",
			"quoteProperties": "asNeeded"
		}
	},
	"overrides": [
		{
			"includes": [
				"**/.devcontainer/**",
				"**/.vscode/**",
				"**/tsconfig*.json",
				"**/.eslintrc.json",
				"**/.swcrc/**"
			],
			"json": {
				"parser": {
					"allowComments": true,
					"allowTrailingCommas": true
				}
			}
		},
	],
	"vcs": {
		"enabled": true,
		"useIgnoreFile": true,
		"clientKind": "git"
	}
}
